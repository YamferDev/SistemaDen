<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.sysdenuncias.controller.CiudadanoController">

    
    <VBox spacing="10" prefWidth="300" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ddd; -fx-border-radius: 5;">
        <Label text="Registro de Ciudadano" styleClass="title-label" />
        
        <Label text="Nombre Completo:" />
        <TextField fx:id="txtNombre" promptText="Ingrese nombre" />
        
        <Label text="DNI:" />
        <TextField fx:id="txtDni" promptText="Ingrese DNI (8 dígitos)" />
        
        <Label text="Teléfono:" />
        <TextField fx:id="txtTelefono" promptText="Ingrese teléfono" />

        <Label text="Correo Electrónico:" />
        <TextField fx:id="txtCorreo" promptText="Ingrese correo" />
        
        <Label text="Dirección:" />
        <TextField fx:id="txtDireccion" promptText="Ingrese dirección" />
        
        <Label text="Género:" />
        <ComboBox fx:id="cbxGenero" prefWidth="260" promptText="Seleccione género" />
        
        <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
            <Button fx:id="btnGuardar" text="Guardar" onAction="#guardar" prefWidth="120" />
            <Button id="btnLimpiar" text="Limpiar" onAction="#limpiar" prefWidth="120" />
        </HBox>
    </VBox>

    
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="Lista de Ciudadanos Registrados" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Buscar:" />
            <TextField fx:id="txtBuscar" promptText="Buscar por nombre o DNI..." HBox.hgrow="ALWAYS" />
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS" />
    </VBox>

</HBox>

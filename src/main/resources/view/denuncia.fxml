<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.sysdenuncias.controller.DenunciaController">

    
    <VBox spacing="10" prefWidth="350" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ddd; -fx-border-radius: 5;">
        <Label text="Gestión de Denuncias" styleClass="title-label" />
        
        <Label text="Ciudadano (Denunciante):" />
        <ComboBox fx:id="cbxCiudadano" prefWidth="310" promptText="Seleccione el ciudadano" />
        
        <Label text="Tipo de Denuncia:" />
        <ComboBox fx:id="cbxTipoDenuncia" prefWidth="310" promptText="Seleccione el tipo" />
        
        <Label text="Estado de Denuncia:" />
        <ComboBox fx:id="cbxEstado" prefWidth="310" promptText="Estado" />
        
        <Label text="Ubicación de los Hechos:" />
        <TextField fx:id="txtUbicacion" promptText="Lugar exacto o referencia" />
        
        <Label text="Descripción Detallada:" />
        <TextArea fx:id="txtDescripcion" promptText="Describa cómo sucedieron los hechos..." prefHeight="100" wrapText="true" />

        <Label text="Observación:" />
        <TextArea fx:id="txtObservacion"
                  promptText="Motivo de rechazo, apelación o comentarios del funcionario..."
                  prefHeight="70"
                  wrapText="true" />
        <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
            <Button fx:id="btnGuardar" text="Guardar" onAction="#guardar" prefWidth="150" />
            <Button id="btnLimpiar" text="Limpiar" onAction="#limpiar" prefWidth="150" />
            <Button text="+ Evidencia" onAction="#subirEvidencia" prefWidth="150" />
        </HBox>
    </VBox>

    
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="Registro de Incidencias" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Buscar:" />
            <TextField fx:id="txtBuscar" promptText="Buscar por descripción, ubicación o ciudadano..." HBox.hgrow="ALWAYS" />
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS" />
    </VBox>

</HBox>

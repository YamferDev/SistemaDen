<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" spacing="20.0" styleClass="login-root" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.sysdenuncias.controller.LoginController">

    <VBox alignment="CENTER" spacing="15.0" styleClass="login-card" maxWidth="350" prefWidth="350" prefHeight="450">

        <StackPane style="-fx-padding: 0 0 10 0;">
            <Circle radius="35.0" fill="#002d40" stroke="WHITE" strokeWidth="1.5" />
            <Label text="👤" style="-fx-font-size: 32px; -fx-text-fill: white;"/>
        </StackPane>

        <Label text="Sistema de Denuncias" styleClass="login-title"/>
        <Label text="Ingreso de Funcionarios" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-weight: bold;"/>

        <VBox spacing="5" alignment="CENTER_LEFT" maxWidth="260">
            <Label text="Usuario (Nombre):" style="-fx-text-fill: white; -fx-font-size: 12px;" />
            <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" styleClass="text-field-modern" prefWidth="260" />
        </VBox>

        <VBox spacing="5" alignment="CENTER_LEFT" maxWidth="260">
            <Label text="Contraseña:" style="-fx-text-fill: white; -fx-font-size: 12px;" />
            <PasswordField fx:id="txtClave" promptText="Ingrese su contraseña" styleClass="text-field-modern" prefWidth="260" />
        </VBox>

        <Button fx:id="btnIngresar" text="LOGIN" onAction="#login" prefWidth="260" styleClass="button-login" style="-fx-margin-top: 10px;" />

        <Button text="Salir" onAction="#cerrar" prefWidth="260" styleClass="button-exit" />

    </VBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="constancia_denuncia"
              pageWidth="595"
              pageHeight="842"
              columnWidth="535"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">


    <parameter name="ID_DENUNCIA" class="java.lang.Long"/>

    <queryString>
        <![CDATA[
    SELECT
        d.id,
        d.fecha,
        d.descripcion,
        d.ubicacion,
        d.observacion,

        CASE d.estado
            WHEN 'PENDIENTE' THEN 'Pendiente'
            WHEN 'EN_PROCESO' THEN 'En Proceso'
            WHEN 'RESUELTO' THEN 'Resuelto'
            WHEN 'NOTIFICADO' THEN 'Notificado'
            WHEN 'EN_APELACION' THEN 'En Apelación'
            WHEN 'RECHAZADO' THEN 'Rechazado'
            ELSE d.estado
        END AS estado_label,

        c.nombre  AS ciudadano_nombre,
        c.dni     AS ciudadano_dni,
        c.telefono AS ciudadano_telefono,
        c.correo  AS ciudadano_correo,

        td.nombre AS tipo_denuncia,

        COALESCE(f.nombre,'SIN FUNCIONARIO ASIGNADO')
            AS funcionario_nombre,

        COALESCE(f.cargo,'')
            AS funcionario_cargo

    FROM denuncia d
    INNER JOIN ciudadano c
        ON d.ciudadano_id = c.id

    INNER JOIN tipo_denuncia td
        ON d.tipo_id = td.id

    LEFT JOIN funcionario f
        ON d.funcionario_id = f.id

    WHERE d.id = $P{ID_DENUNCIA}
    ]]>
    </queryString>

    <field name="id" class="java.lang.Long"/>
    <field name="fecha" class="java.sql.Timestamp"/>
    <field name="descripcion" class="java.lang.String"/>
    <field name="ubicacion" class="java.lang.String"/>
    <field name="observacion" class="java.lang.String"/>
    <field name="estado_label" class="java.lang.String"/>

    <field name="ciudadano_nombre" class="java.lang.String"/>
    <field name="ciudadano_dni" class="java.lang.String"/>
    <field name="ciudadano_telefono" class="java.lang.String"/>
    <field name="ciudadano_correo" class="java.lang.String"/>

    <field name="tipo_denuncia" class="java.lang.String"/>

    <field name="funcionario_nombre" class="java.lang.String"/>
    <field name="funcionario_cargo" class="java.lang.String"/>

    <title>
        <band height="120">

            <rectangle>
                <reportElement x="0" y="0" width="535" height="10"/>
            </rectangle>

            <staticText>
                <reportElement x="0" y="20" width="535" height="22"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[MUNICIPALIDAD PROVINCIAL DE PUNO]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="45" width="535" height="18"/>
                <textElement textAlignment="Center">
                    <font size="11"/>
                </textElement>
                <text><![CDATA[GERENCIA DE SEGURIDAD CIUDADANA]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="80" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[CONSTANCIA DE DENUNCIA CIUDADANA]]></text>
            </staticText>

        </band>
    </title>

    <detail>
        <band height="520">

            <textField>
                <reportElement x="0" y="0" width="250" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                "Código N° " + String.format("%06d",$F{id})
            ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="35" width="250" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[I. DATOS DEL HECHO]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="65" width="120" height="18"/>
                <text><![CDATA[Fecha de registro:]]></text>
            </staticText>

            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="140" y="65" width="200" height="18"/>
                <textFieldExpression><![CDATA[$F{fecha}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="90" width="120" height="18"/>
                <text><![CDATA[Ubicación:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="90" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{ubicacion}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="130" width="250" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[II. DATOS DEL DENUNCIANTE]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="160" width="120" height="18"/>
                <text><![CDATA[Nombre:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="160" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{ciudadano_nombre}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="185" width="120" height="18"/>
                <text><![CDATA[DNI:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="185" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{ciudadano_dni}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="210" width="120" height="18"/>
                <text><![CDATA[Teléfono:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="210" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{ciudadano_telefono}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="235" width="120" height="18"/>
                <text><![CDATA[Correo:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="235" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{ciudadano_correo}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="280" width="250" height="18"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[III. DATOS DE LA DENUNCIA]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="305" width="120" height="18"/>
                <text><![CDATA[Tipo:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="305" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{tipo_denuncia}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="330" width="120" height="18"/>
                <text><![CDATA[Estado:]]></text>
            </staticText>

            <textField>
                <reportElement x="140" y="330" width="350" height="18"/>
                <textFieldExpression><![CDATA[$F{estado_label}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="365" width="150" height="18"/>
                <text><![CDATA[Descripción:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="390" width="500" height="50"/>
                <textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="450" width="150" height="18"/>
                <text><![CDATA[Observaciones:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="475" width="500" height="40"/>
                <textFieldExpression><![CDATA[
                $F{observacion} == null ? "" : $F{observacion}
            ]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <pageFooter>
        <band height="110">

            <line>
                <reportElement x="140" y="10" width="250" height="1"/>
            </line>

            <textField>
                <reportElement x="140" y="15" width="250" height="18"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{funcionario_nombre}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="140" y="35" width="250" height="18"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{funcionario_cargo}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="65" width="535" height="15"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Documento generado automáticamente por el Sistema de Gestión de Denuncias]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="95" width="535" height="10"/>
            </rectangle>

        </band>
    </pageFooter>
</jasperReport>
